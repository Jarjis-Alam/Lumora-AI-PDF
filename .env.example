# ──────────────────────────────────────────────────────────
# Lumora Frontend — Environment Variables
# Copy this file to .env inside the root directory and modify.
# ──────────────────────────────────────────────────────────

# Base URL pointing to the FastAPI backend API
# Local development:  VITE_API_BASE_URL=http://localhost:8000/api
# Production (Render): VITE_API_BASE_URL=https://lumora-backend-fic8.onrender.com/api
VITE_API_BASE_URL=http://localhost:8000/api
